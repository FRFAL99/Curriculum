# Copia questo file in .env (gitignored) e inserisci la tua chiave reale.
# Serve solo per `npm run dev:full` (netlify dev) in locale — vedi docs/FASE10_LOG.md.
# Per sbloccare il limite di 1000 richieste/giorno (invece di 50) sui modelli
# :free, serve aver acquistato almeno $10 di credito una tantum sull'account
# OpenRouter (non viene speso dai modelli gratuiti).

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free
