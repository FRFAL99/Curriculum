# Copia questo file in .env (gitignored) e inserisci la tua chiave reale.
# Serve solo per `npm run dev:full` (netlify dev) in locale — vedi docs/FASE10_LOG.md.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Usato solo se il modello primario risponde 503 (overloaded) anche dopo i retry.
GEMINI_FALLBACK_MODEL=gemini-flash-lite-latest
