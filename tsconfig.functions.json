{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.functions.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "skipLibCheck": true,

    /* Bundler mode — le function vengono impacchettate da esbuild
       (Netlify zip-it-and-ship-it), non eseguite come ESM Node grezzo:
       stessa strategia di risoluzione di tsconfig.app.json, niente
       necessità di estensioni esplicite negli import relativi. */
    "moduleResolution": "bundler",
    "module": "esnext",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["netlify/functions"]
}
